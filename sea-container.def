BootStrap: docker
From: ubuntu:22.04
From: gcc

%environment
    export APPTAINER_INSTALL=YES
    export APPTAINER_LAUNCH=YES

%post
    apt-get -y update
    apt-get -y install git 
    apt-get -y install software-properties-common
    apt-get -y install sudo
    mkdir sea
    cd sea
    git clone https://smith-nekrald@github.com/smith-nekrald/sea-code.git
    mv sea-code code
    cd code
    git submodule update --init --recursive
    export APPTAINER_INSTALL=YES
    mkdir -p experiment
    cd ..
    code/setup_system.sh
   
%labels
    Author "Aliaksandr Nekrashevich"

